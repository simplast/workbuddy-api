# CodeBuddy API 配置
# 方式一：直接填 API Key（从 codebuddy.ai/profile 获取）
# 方式二：CLI 登录后从浏览器 DevTools > Application > LocalStorage 中提取 accessToken
CODEBUDDY_API_KEY=your-api-key-or-access-token-here

# CodeBuddy API 地址（默认即可，一般不需要改）
CODEBUDDY_BASE_URL=https://www.codebuddy.ai

# 本地 proxy 服务配置
PORT=3456
HOST=127.0.0.1

# 可选：默认模型
DEFAULT_MODEL=default-model
