# ─── Multi-provider config ────────────────────────────────────────────
#
# Two base protocols are supported: 'openai' and 'anthropic'. Private
# providers (codebuddy, nvidia) are patches on top of one of these — they
# add custom headers, model-name aliases, and rate limiting, but never
# invent a third wire format. Add a new private provider by subclassing
# OpenAIProvider or AnthropicProvider in src/providers/.
#
# Each provider is enabled by setting its API key. Set DEFAULT_PROVIDER
# to choose the fallback when a request model isn't claimed by anyone.
#
# ─── codebuddy (OpenAI protocol + CLI request-header fingerprint) ─────
CODEBUDDY_API_KEY=your-api-key-or-access-token-here

# Copilot Cloud API (internal, mainland China): https://copilot.tencent.com
# CodeBuddy Global API (external): https://www.codebuddy.ai
# CODEBUDDY_BASE_URL=https://copilot.tencent.com

# CODEBUDDY_MODELS=default-model,glm-5.1,claude-sonnet-4.5
# CODEBUDDY_TARGET_MODEL=actual-upstream-model
# CODEBUDDY_CLI_VERSION=2.110.0   # override auto-detected CLI version

# ─── nvidia (OpenAI protocol, with per-provider rate limiting) ────────
# NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODELS=glm-5.1
# NVIDIA_TARGET_MODEL=z-ai/glm-5.1
# NVIDIA_RPM=40
# NVIDIA_BURST=5

# ─── Routing ──────────────────────────────────────────────────────────
# DEFAULT_PROVIDER=codebuddy
# DEFAULT_MODEL=default-model

# ─── Local proxy server ──────────────────────────────────────────────
PORT=3456
HOST=127.0.0.1
